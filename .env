# Works out of the box for local development with `make backend.up.dev`

# For sensitive credentials (Google OAuth, Slack), create a .env.local file —
# it is git-ignored and will not be committed to the repo.
# See the "Sensitive credentials" section at the bottom for the variables to
# add there.

# !! MUST change in production !!
#
#   SECRET_KEY                  openssl rand -hex 32
#   LLM_ENCRYPTION_KEY          python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   CHAT_ENCRYPTION_KEY         same as above
#   POSTGRES_PASSWORD           use a strong random password
#   DATABASE_URL                managed database URL
#   REDIS_URL                   managed Redis URL
#
#   FRONTEND_BASE_URL           your public domain (e.g. https://sparkth.example.com)
#   GOOGLE_AUTH_REDIRECT_URI    update hostname to your public domain
#   GOOGLE_DRIVE_REDIRECT_URI   update hostname to your public domain
#   SLACK_REDIRECT_URI          update hostname to your public domain
#   SMTP_HOST                   your SMTP provider host (e.g. email-smtp.us-east-1.amazonaws.com)
#   SMTP_PORT                   587 (STARTTLS) or 465 (SSL)
#   SMTP_USE_TLS                true
#   SMTP_FROM_EMAIL             a verified sender address for your domain
#   REGISTRATION_ENABLED        [Optional] consider false to restrict open sign-ups

# App
PORT=7727
REGISTRATION_ENABLED=true

# Database
POSTGRES_USER=sparkth
POSTGRES_PASSWORD=sparkth_password
POSTGRES_DB=sparkth
# The backend runs natively in development and connects to the Postgres container
# published on localhost:5432 (see docker-compose.yml). In production, set a managed
# database URL via the environment / .env.local.
DATABASE_URL=postgresql://sparkth:sparkth_password@localhost:5432/sparkth

# Redis
# Connects to the Redis container published on localhost:6379 (see docker-compose.yml).
REDIS_URL=redis://localhost:6379

# SMTP
# Dev default: Mailpit (local SMTP server bundled with docker-compose), published on
# localhost:1025. For production, set real SMTP credentials below or in .env.local.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=no-reply@sparkth.dev
SMTP_FROM_NAME=Sparkth

# Email verification
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
FRONTEND_BASE_URL=http://localhost:7727

# Mailpit
MP_MAX_MESSAGES=5000
MP_SMTP_AUTH_ACCEPT_ANY=1
MP_SMTP_AUTH_ALLOW_INSECURE=1

# RAG Pipeline
RAG_STORE_BATCH_SIZE=32
RAG_EXTRACTION_BATCH_SIZE=0

# Memory Profiling
MEMORY_PROFILING_ENABLED=false

# Google OAuth
GOOGLE_AUTH_REDIRECT_URI=http://localhost:7727/api/v1/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:7727/api/v1/googledrive/oauth/callback
# Drive file-ingestion guards (the client enforces these; RAG does not limit file size)
INGESTION_CONCURRENCY=1
INGESTION_MAX_FILE_SIZE_MB=50
# The variables below contain OAuth secrets and cannot be committed to the repo.
# Create a .env.local file (already in .gitignore) and add them there:
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Slack
SLACK_MAX_AGENT_FILES=5
SLACK_REDIRECT_URI=http://localhost:7727/api/v1/slack/oauth/callback
# The variables below contain secrets and cannot be committed to the repo.
# Create a .env.local file (already in .gitignore) and add them there:
# SLACK_CLIENT_ID=...
# SLACK_CLIENT_SECRET=...
# SLACK_SIGNING_SECRET=...

# DEV Encryption Keys
SECRET_KEY=921133f9384338c5301da016787beb7f
LLM_ENCRYPTION_KEY=Smj39CUf5BMm_cW8Am4GyYM6O9mTqgflc4if7lW5SQk=
CHAT_ENCRYPTION_KEY=2SUrze0VjUKaj93UPM2mMDgPwN8ZSSS3H89cck9GITY=
